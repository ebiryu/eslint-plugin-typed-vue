{
  "name": "eslint-plugin-typed-vue",
  "version": "0.2.0",
  "description": "ESLint plugin that enables typescript-eslint type-aware rules for Vue SFC files",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebiryu/eslint-plugin-typed-vue"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bench": "node benchmarks/bench.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@vue/language-core": "^3.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "@volar/language-core": "^2.4.28",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "oxfmt": "^0.37.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.0",
    "vitest": "^4.0.0",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.0.0"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": ">=8.0.0",
    "eslint": ">=9.0.0",
    "eslint-plugin-vue": ">=10.0.0",
    "typescript": ">=5.0.0",
    "vue-eslint-parser": ">=9.0.0"
  }
}
